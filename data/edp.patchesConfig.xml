			<ControlChange group="B" controller="59" value="127" />
		</patch>
		<patch name="EDP Rec/Mute mom" type="momentary" device="EDP">
			<midiByteString name="A">b6 26 7f b6 26 00</midiByteString>
			<midiByteString name="B">b6 2a 7f b6 2a 00</midiByteString>
		</patch>

