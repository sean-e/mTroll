		<patch name="EDP SusRndInsert" type="momentaryControlChange" device="EDP" controller="53" />
		<patch name="EDP SusMute" type="momentaryControlChange" device="EDP" controller="54" />
		<patch name="EDP Mute" type="momentary" device="EDP">
			<ControlChange group="A" controller="54" value="127" />
		</patch>
		<patch name="EDP SusMute (volCont)" type="momentary" device="EDP">
			<ControlChange group="A" controller="1" value="0" />
			<ControlChange group="B" controller="1" value="127" />
		</patch>
		<patch name="EDP TglMute (volCont)" type="toggle" device="EDP">
			<ControlChange group="A" controller="1" value="0" />
			<ControlChange group="B" controller="1" value="127" />
		</patch>
		<patch name="EDP ShortUndo" type="momentary" device="EDP">
			<ControlChange group="A" controller="55" value="127" /> <!-- is this right? causes unexpected record after loop select? -->
		</patch>
		<patch name="EDP SusNextLoop" type="momentaryControlChange" device="EDP" controller="56" />
		<patch name="EDP SusReplace" type="momentaryControlChange" device="EDP" controller="57" />
		<patch name="EDP SusSubstitute" type="momentaryControlChange" device="EDP" controller="58" />
		<patch name="EDP SusReverse" type="momentaryControlChange" device="EDP" controller="59" />
