		<patch name="EDP SusSpeed" type="momentaryControlChange" device="EDP" controller="60" />
		<patch name="EDP TglSpeed" type="toggleControlChange" device="EDP" controller="60" />
		<patch name="EDP Reset" type="momentary" device="EDP">
