		</patch>
		<patch name="EDP MIDI BeatSync" type="momentary" device="EDP">
			<ControlChange group="A" controller="81" value="127" />
		</patch>

		<!-- EDP Loop Triggers
			LoopTriggering only works via NoteOn
			loop play is dependent upon SamplerStyle
			NoteOff is required else loop gets erased 
		-->
		<patch name="EDP Loop 1" type="normal" groupId="EdpLoop" device="EDP">
			<NoteOn group="A" note="84" velocity="127" />
			<NoteOff group="A" note="84" velocity="0" />
		</patch>
